<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!--
        NOTE: This file previously contained libgazebo_ros_diff_drive.so (Gazebo Classic plugin).
        That plugin is INCOMPATIBLE with Ignition Fortress / ROS2 Humble.
        Control is now handled exclusively via ros2_control.xacro using:
          - ign_ros2_control/GazeboSimSystem (sim mode)
          - esp32_hardware/L298Hardware (real robot mode)

        The gz.launch.py spawns joint_state_broadcaster and diff_drive_controller
        via controller_manager spawner nodes, which provide wheel /tf and /joint_states.

        IMU sensor plugin is self-contained in description/xacro/imu.xacro.
        The ros_gz_bridge entry for /imu is in launch/gz.launch.py.
        DO NOT re-add libgazebo_ros_diff_drive.so — it will conflict with ros2_control.
        DO NOT add libgazebo_ros_imu_sensor.so — that is Gazebo Classic, not Ignition.
    -->

</robot>
