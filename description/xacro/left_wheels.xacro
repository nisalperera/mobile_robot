<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <xacro:include filename="$(find mobile_robot)/description/xacro/inertial_macros.xacro" />

    <!-- Front wheel -->
    <joint name="front_left_wheel_joint" type="continuous">
        <parent link="chassis" />
        <child link="front_left_wheel" />
        <origin xyz="0.25 0.175 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1" />
    </joint>

    <link name="front_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.024" length="0.025" />
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.024" length="0.025" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.025" radius="0.024">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- Rear wheel -->
    <joint name="rear_left_wheel_joint" type="continuous">
        <parent link="chassis" />
        <child link="rear_left_wheel" />
        <origin xyz="0.05 0.175 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1" />
    </joint>

    <link name="rear_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.024" length="0.025" />
            </geometry>
            <material name="black" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.024" length="0.025" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.025" radius="0.024">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!--
         Ignition Gazebo friction and contact properties for left wheels.

         mu  (ODE mu1) = 1.0  - forward/rolling friction coefficient.
             Rubber-on-concrete typical value. Prevents the wheel from
             sliding forward/backward under drive torque.

         mu2 (ODE mu2) = 0.5  - lateral friction coefficient.
             Lower than mu1 to allow the lateral scrub a 4-wheel
             skid-steer robot produces during turns.
             mu2=0.0 -> wheels slide freely -> phantom lateral velocity
             in odometry -> SLAM map->odom drift/jumps.

         kp  = 1e6 N/m - contact stiffness (spring constant).
             Prevents wheels sinking into the ground plane.

         kd  = 1.0 Ns/m - contact damping.
             Damps bounce at spawn. Without this the robot oscillates
             vertically after spawn, corrupting the first odom samples.

         minDepth = 0.001 m - minimum penetration before friction fires.
             Prevents jitter from micro-penetrations at rest.
    -->
    <gazebo reference="front_left_wheel">
        <material>Gazebo/Black</material>
        <mu>1.0</mu>
        <mu2>0.5</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
    </gazebo>

    <gazebo reference="rear_left_wheel">
        <material>Gazebo/Black</material>
        <mu>1.0</mu>
        <mu2>0.5</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
    </gazebo>

</robot>
