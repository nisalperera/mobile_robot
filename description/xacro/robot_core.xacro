<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find mobile_robot)/description/xacro/colors.xacro" />
    <xacro:include filename="$(find mobile_robot)/description/xacro/inertial_macros.xacro" />
    <xacro:include filename="$(find mobile_robot)/description/xacro/lidar.xacro" />
    <xacro:include filename="$(find mobile_robot)/description/xacro/right_camera.xacro" />
    <xacro:include filename="$(find mobile_robot)/description/xacro/left_camera.xacro" />
    <xacro:include filename="$(find mobile_robot)/description/xacro/left_wheels.xacro" />
    <xacro:include filename="$(find mobile_robot)/description/xacro/right_wheels.xacro" />
    <!-- IMU sensor: adds imu_link, imu_joint, and Ignition IMU plugin -->
    <xacro:include filename="$(find mobile_robot)/description/xacro/imu.xacro" />

    <!--
        IMPORTANT: base_footprint MUST be declared first so that every URDF
        parser (including ROS2 Foxy's urdf_parser) correctly identifies it as
        the root link. The root is determined by finding a link that never
        appears as a <child> in any joint. If base_link is declared first,
        older parsers may pick it as root and publish base_link→base_footprint
        (inverted), which breaks the entire TF chain:
          map → odom → base_footprint → base_link  (correct)
          map → odom → base_link → base_footprint  (WRONG — breaks Nav2 / SLAM)
    -->

    <!-- Virtual root link: no geometry, no inertia, sits on the ground plane -->
    <link name="base_footprint"/>

    <!-- base_footprint → base_link (fixed, zero offset) -->
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child  link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link"/>

    <!-- base_link → chassis -->
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child  link="chassis"/>
        <origin xyz="-0.1 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.15 0 0.075" />
            <geometry>
                <box size="0.3 0.3 0.15" />
            </geometry>
            <material name="white" />
        </visual>
        <collision>
            <origin xyz="0.15 0 0.075" />
            <geometry>
                <box size="0.3 0.3 0.15" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.3" y="0.3" z="0.15">
            <origin xyz="0.15 0 0.075" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/White</material>
    </gazebo>

</robot>
